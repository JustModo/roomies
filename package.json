{
  "name": "watch-party-monorepo",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "docker compose up -d --build",
    "dev": "concurrently \"docker compose -f docker-compose.dev.yml up\" \"turbo run dev\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.10.3",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
