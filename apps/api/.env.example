# Copy this to .env and fill in values before running

# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://roomies:password@localhost:5432/roomies

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_string

# ── Transcoding ──────────────────────────────────────
# Path to ffmpeg binary. Leave blank to use system PATH.
FFMPEG_PATH=ffmpeg
# Absolute path to HLS output directory
CACHE_DIR=../../cache
# Base URL Caddy uses to serve HLS playlists to clients
HLS_BASE_URL=http://localhost/hls
