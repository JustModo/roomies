{
  "name": "@roomies/server",
  "private": true,
  "scripts": {
    "dev": "cross-env DATABASE_URL=file:../../config/roomies.db prisma generate && cross-env DATABASE_URL=file:../../config/roomies.db prisma db push --accept-data-loss && tsx watch src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@libsql/client": "^0.6.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@roomies/chat": "workspace:*",
    "@roomies/config": "workspace:*",
    "@roomies/contracts": "workspace:*",
    "@roomies/library": "workspace:*",
    "@roomies/transcoding": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "cross-env": "^10.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.0.0"
  }
}
