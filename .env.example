# ── Roomies Global Configuration ───────────────────────

# Absolute or relative path to the folder containing your movies and TV shows
MEDIA_DIR=./media

# ── Advanced (optional) ────────────────────────────────
# Only needed if your ffmpeg build doesn't include libx264 (the default video
# encoder used for HLS transcoding). Override to whatever H.264 encoder your
# ffmpeg build provides (e.g. libopenh264) and its matching option syntax —
# `-profile:v`/`-level` accept different values per encoder.
# FFMPEG_VIDEO_CODEC=libx264
# FFMPEG_VIDEO_CODEC_ARGS=-profile:v baseline -level 3.0
