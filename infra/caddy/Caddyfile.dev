# Roomies - Unified Reverse Proxy (DEV MODE)

{
    admin off
    log {
        output stderr
        format console
    }
}

:5123 {
    # --- API Routes (Fastify backend) ---
    handle /api/* {
        reverse_proxy host.docker.internal:3000
    }

    # --- WebSocket Gateway ---
    handle /ws* {
        reverse_proxy host.docker.internal:3000
    }

    # --- HLS Media Delivery ---
    # MIME types are auto-detected by Caddy's file_server (m3u8 → mpegurl, ts → MP2T).
    handle /hls/* {
        root * /cache
        uri strip_prefix /hls
        file_server

        header {
            Access-Control-Allow-Origin *
            Cache-Control "no-store, no-cache, must-revalidate"
        }
    }

    # --- React Frontend (Vite Dev Server) ---
    handle {
        reverse_proxy host.docker.internal:5173
    }
}
