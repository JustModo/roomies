# Roomies - Unified Reverse Proxy
# Single entrypoint routing to internal services

{
    # Global options
    admin off
    log {
        output stderr
        format console
    }
}

:5123 {
    # --- API Routes (Fastify backend) ---
    handle /api/* {
        reverse_proxy 127.0.0.1:3000
    }

    # --- WebSocket Gateway ---
    handle /ws* {
        reverse_proxy 127.0.0.1:3000
    }

    # --- HLS Media Delivery (served from shared cache volume) ---
    handle /hls/* {
        root * /cache
        uri strip_prefix /hls
        file_server

        header {
            Access-Control-Allow-Origin *
        }

        # NOTE: Segments are immutable once written (seek/restart always gets a fresh
        # randomly-suffixed directory), so they can be cached forever. The playlist keeps
        # growing as new segments are appended, so it must never be cached.
        @segments path *.ts
        header @segments Cache-Control "public, max-age=31536000, immutable"

        @playlists path *.m3u8
        header @playlists Cache-Control "no-store, no-cache, must-revalidate"
    }

    # --- React Frontend (built static files) ---
    handle {
        root * /app/apps/web/dist
        try_files {path} {path}/ /index.html
        file_server
    }
}
